# LLM Provider Configuration
# Choose one: anthropic (default), openai, gemini, or mock (offline, no key needed)
LLM_PROVIDER=anthropic

# API Keys (only set the one matching your provider; 'mock' needs none)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# Gemini: use a real API key (starts AIza) from https://aistudio.google.com/apikey,
# NOT a short-lived OAuth access token.
# GEMINI_API_KEY=AIza...

# LLM Model Configuration (optional, defaults provided)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.5-pro   # better quality; lower free-tier daily limit (fine for the
                                # daily progressive run). Use gemini-2.5-flash for higher throughput.

# Scraper Configuration
# USER_AGENT=Mozilla/5.0 (compatible; PlanthoodScraper/1.0)
# REQUEST_DELAY=1.0

# Enrichment cache (skip re-calling the LLM for unchanged recipes)
# Cache lives under data/.cache/enrich; pass --no-cache to the CLI to bypass.
